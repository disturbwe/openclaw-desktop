{
  "name": "openclaw-desktop",
  "version": "1.0.0",
  "description": "OpenClaw Desktop - Electron 桌面应用",
  "main": "src/main/index.js",
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "dev": "cross-env NODE_ENV=development npm run dev:all",
    "dev:all": "concurrently \"vite\" \"wait-on http://localhost:5173 && npx electron . --enable-logging\"",
    "dev:vite": "vite",
    "build": "npm run build:renderer && electron-builder",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:renderer": "npm run build:ui && tsc && vite build",
    "build:ui": "cd openclaw-core/ui && npm run build",
    "postinstall": "cd openclaw-core && pnpm install && pnpm build"
  },
  "author": "distubwe",
  "license": "MIT",
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@tanstack/react-query": "^5.90.21",
    "antd": "^6.3.2",
    "electron-log": "^5.0.0",
    "i18next": "^25.8.18",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^34.5.8",
    "electron-builder": "^24.9.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "ai.openclaw.desktop",
    "productName": "OpenClaw Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "dist/**/*",
      "assets/**/*",
      "openclaw-core/dist/**/*",
      "openclaw-core/node_modules/**/*",
      "openclaw-core/package.json",
      "openclaw-core/openclaw.mjs",
      "!openclaw-core/src/**/*",
      "!openclaw-core/test/**/*",
      "!openclaw-core/docs/**/*"
    ],
    "extraResources": [
      {
        "from": "openclaw-core/dist",
        "to": "openclaw-core/dist"
      },
      {
        "from": "openclaw-core/node_modules",
        "to": "openclaw-core/node_modules"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
